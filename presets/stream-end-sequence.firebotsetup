              "type": "firebot:html",
              "active": true,
              "html": "<div style=\"font-family:sans-serif;color:#fff;text-align:center;padding-top:35vh;font-size:3rem\">Thanks for watching &mdash; see you next stream! 👋</div>",
              "length": 8,
              "overlayInstance": "%FAREWELL_OVERLAY_INSTANCE%",
              "enterAnimation": "fadeIn",
              "enterDuration": "0.5",
              "exitAnimation": "fadeOut",
              "exitDuration": "0.5",
              "percentWeight": null,
              "effectLabel": "Farewell on its own overlay instance — replace with your own content"
            }
          ],
          "runMode": "all"
        },
