  "importQuestions": [
    {
      "id": "bc47b7d0-8dff-40b9-a90f-13d275f08ba6",
      "question": "What is the name of your OBS browser source for the credits?",
      "answerType": "text",
      "replaceToken": "%CREDITS_BROWSER_SOURCE%",
      "helpText": "The OBS browser source whose URL gets set to the generated credits view. You can also pick it from the dropdown in each effect after import.",
      "defaultAnswer": "Credits"
    },
    {
      "id": "4dc2824b-e85c-4e52-ba0d-af78cd824b2c",
      "question": "Which OBS scene shows the credits roll?",
      "answerType": "text",
      "replaceToken": "%ENDING_SCENE%",
      "helpText": "Firebot switches to this scene to reveal the credits.",
      "defaultAnswer": "Ending Credits Roll"
    },
    {
      "id": "12b9d90c-27fb-41f0-a54e-157f9592fe6f",
      "question": "Which OBS scene should Firebot switch back to after the credits finish?",
      "answerType": "text",
      "replaceToken": "%RETURN_SCENE%",
      "helpText": "Used by the Credits Ended event handler.",
      "defaultAnswer": "Starting Soon"
    },
    {
      "id": "a0d94c2f-ead1-4ab1-a64f-57e5fa2eadc5",
      "question": "Which Firebot overlay instance hosts the farewell?",
      "answerType": "text",
      "replaceToken": "%FAREWELL_OVERLAY_INSTANCE%",
      "helpText": "Create a dedicated overlay instance in Settings > Overlay (e.g. \"farewell\"). Only used by the live sequence.",
      "defaultAnswer": "farewell"
    }
  ]
